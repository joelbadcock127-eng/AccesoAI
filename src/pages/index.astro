---
import '../styles/global.css';

const useCases = [
  {
    title: "Sales enquiry assistant",
    body: "Respond faster to common customer questions and route enquiries to the right person — without extra headcount.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M8.625 12a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H8.25m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H12m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 0 1-2.555-.337A5.972 5.972 0 0 1 5.41 20.97a5.969 5.969 0 0 1-.474-.065 4.48 4.48 0 0 0 .978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25Z" /></svg>`
  },
  {
    title: "Quote and follow-up automation",
    body: "Create draft quotes, send automated follow-ups, and stop chasing deals manually — so no opportunity slips through.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" /></svg>`
  },
  {
    title: "Admin workflow automation",
    body: "Turn repetitive internal processes into structured automated workflows. Less time on data entry, more time on real work.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 12h16.5m-16.5 3.75h16.5M3.75 19.5h16.5M5.625 4.5h12.75a1.875 1.875 0 0 1 0 3.75H5.625a1.875 1.875 0 0 1 0-3.75Z" /></svg>`
  },
  {
    title: "AI knowledge assistant",
    body: "Let staff ask questions and instantly retrieve procedures, policies, or service information — without calling the one person who knows.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 18v-5.25m0 0a6.01 6.01 0 0 0 1.5-.189m-1.5.189a6.01 6.01 0 0 1-1.5-.189m3.75 7.478a12.06 12.06 0 0 1-4.5 0m3.75 2.383a14.406 14.406 0 0 1-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 1 0-7.517 0c.85.493 1.509 1.333 1.509 2.316V18" /></svg>`
  },
  {
    title: "Marketing content assistant",
    body: "Generate first-draft social posts, emails, website copy, and campaign ideas — built around your actual business, not generic templates.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10" /></svg>`
  },
  {
    title: "Reporting automation",
    body: "Stop building reports by hand. Automate data collection and reporting so your team has clearer information with less effort.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z" /></svg>`
  }
];

const outcomes = [
  {
    industry: "Trades Business",
    before: "A business owner manually answers every enquiry, creates quotes from scratch, and follows up inconsistently — often letting warm leads go cold.",
    after: "AI drafts enquiry responses, prepares quote information, and triggers follow-up reminders at the right time.",
    result: "Faster response times, less admin, and fewer missed opportunities."
  },
  {
    industry: "Professional Services",
    before: "Staff spend hours each week writing the same types of emails, reports, and client updates — pulling them away from billable work.",
    after: "AI generates first drafts for recurring communications, saving each team member hours per week.",
    result: "More capacity for high-value work without adding headcount."
  },
  {
    industry: "Hospitality / Tourism",
    before: "Booking enquiries arrive at all hours. Without immediate responses, potential guests book elsewhere.",
    after: "An AI assistant handles common booking questions and qualifies enquiries 24 hours a day.",
    result: "More bookings captured outside business hours, with less time spent on repetitive customer communication."
  }
];

const services = [
  {
    num: "01",
    title: "AI Opportunity Review",
    body: "A focused review of your business processes to identify where AI and automation could make a practical difference. Clear priorities, realistic options."
  },
  {
    num: "02",
    title: "Workflow Automation",
    body: "Design and implementation of automations for admin, enquiries, forms, reporting, and internal processes. Built to work the way your business already works."
  },
  {
    num: "03",
    title: "AI Assistants",
    body: "Custom AI assistants trained around your business information, procedures, documents, or customer questions."
  },
  {
    num: "04",
    title: "Website & Lead Systems",
    body: "Improving how your website captures, qualifies, and responds to leads — so fewer opportunities are missed."
  },
  {
    num: "05",
    title: "Staff AI Enablement",
    body: "Helping business owners and teams use AI safely and effectively in daily work, with practical training built around real business scenarios."
  }
];

const faqs = [
  {
    q: "Do I need to understand AI before working with you?",
    a: "No. The goal is to make AI practical and understandable. You do not need any technical background. Most of the work happens on your business processes, not the technology."
  },
  {
    q: "Is this only for large businesses?",
    a: "No. Acceso AI is focused on small and medium businesses. The tools and systems used are chosen to be appropriate for the size and budget of the business involved."
  },
  {
    q: "What if AI isn't useful for my business?",
    a: "Then the recommendation will be honest. The goal is to identify worthwhile opportunities, not force AI into places it does not belong. Some businesses will benefit more than others, and the assessment is designed to show that clearly."
  },
  {
    q: "Will AI replace my staff?",
    a: "The focus is almost always on reducing repetitive work and helping staff work more effectively — not replacing people. In most small businesses, the challenge is not too many staff, it's not enough time to get everything done."
  },
  {
    q: "Is my business data safe?",
    a: "Data handling depends on the specific tools and workflows used. Privacy and security are considered during every implementation. The right approach is discussed before anything is built."
  },
  {
    q: "How do I start?",
    a: "The best starting point is the free AI Opportunity Assessment. It takes around 5–7 minutes and produces a personalised report showing where AI may be most useful in your business. If you already have a specific problem or project in mind, you can also contact Acceso AI directly."
  }
];
---

<!DOCTYPE html>
<html lang="en-AU">
<head>
  <meta charset="utf-8" />
  <link rel="icon" href="/favicon.ico" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content="Acceso AI helps Australian small and medium businesses save time, reduce admin, and improve operations with practical AI and automation. Based in Devonport, Tasmania." />
  <meta name="keywords" content="AI consultant Australia, AI consultant Tasmania, AI consulting for small business, business automation consultant, AI automation for small business, workflow automation consultant, practical AI for business" />
  <title>Acceso AI — Practical AI Consulting for Australian Businesses</title>

  <!-- Open Graph -->
  <meta property="og:title" content="Acceso AI — Practical AI Consulting for Australian Businesses" />
  <meta property="og:description" content="Practical AI systems that save time, reduce admin, and make your business easier to run." />
  <meta property="og:type" content="website" />
</head>
<body>

  <!-- ══════════════════════════════════════════════
       NAVIGATION
  ══════════════════════════════════════════════ -->
  <nav class="site-nav" aria-label="Main navigation">
    <div class="nav-inner">
      <a href="/" class="nav-logo">Acceso AI</a>

      <ul class="nav-links">
        <li><a href="#assessment">Assessment</a></li>
        <li><a href="#services">Services</a></li>
        <li><a href="#about">About</a></li>
        <li><a href="#faq">FAQ</a></li>
        <li><a href="#assessment" class="nav-cta">Take the Assessment</a></li>
      </ul>

      <button class="nav-toggle" aria-label="Toggle menu" id="nav-toggle">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor" width="24" height="24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
      </button>
    </div>
  </nav>

  <div class="mobile-nav" id="mobile-nav" aria-label="Mobile navigation">
    <a href="#assessment">Assessment</a>
    <a href="#services">Services</a>
    <a href="#about">About</a>
    <a href="#faq">FAQ</a>
    <a href="#assessment" style="color:var(--accent); font-weight:600;">Take the Assessment →</a>
    <a href="mailto:hello@accesoai.com.au" style="color:var(--muted);">Contact</a>
  </div>


  <!-- ══════════════════════════════════════════════
       1. HERO
  ══════════════════════════════════════════════ -->
  <section id="hero">
    <div class="container">
      <div style="max-width: 780px;">
        <div class="hero-badge hero-line">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="14" height="14"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" /></svg>
          Based in Devonport, Tasmania · Serving Australian businesses
        </div>

        <h1 class="display-xl hero-line" style="margin-bottom: 1.5rem;">
          Practical AI systems that make your business easier to run.
        </h1>

        <p class="body-lg hero-line" style="max-width: 580px; margin-bottom: 0;">
          Acceso AI helps Australian businesses identify repetitive work, customer bottlenecks, and missed opportunities — then builds practical AI and automation systems to fix them.
        </p>

        <div class="hero-ctas hero-line">
          <a href="#assessment" class="btn btn-primary">Take the Free AI Opportunity Assessment</a>
          <a href="mailto:hello@accesoai.com.au" class="btn btn-secondary">Contact Acceso AI</a>
        </div>

        <div class="hero-divider hero-line">
          Trusted by Australian small and medium businesses
        </div>
      </div>
    </div>
  </section>


  <!-- ══════════════════════════════════════════════
       2. TRUST STRIP
  ══════════════════════════════════════════════ -->
  <section id="trust">
    <div class="container">
      <div class="trust-grid">

        <div class="trust-item reveal">
          <div class="trust-icon">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21v-8.25M15.75 21v-8.25M8.25 21v-8.25M3 9l9-6 9 6m-1.5 12V10.332A48.36 48.36 0 0 0 12 9.75c-2.551 0-5.056.2-7.5.582V21M3 21h18M12 6.75h.008v.008H12V6.75Z" /></svg>
          </div>
          <div>
            <div class="trust-item-text" style="font-weight:600; color:var(--text); margin-bottom:0.25rem;">AI & Automation Officer</div>
            <div class="trust-item-text">Devonport City Council — real systems in real organisations</div>
          </div>
        </div>

        <div class="trust-item reveal">
          <div class="trust-icon">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 0 1-1.043 3.296 3.745 3.745 0 0 1-3.296 1.043A3.745 3.745 0 0 1 12 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 0 1-3.296-1.043 3.745 3.745 0 0 1-1.043-3.296A3.745 3.745 0 0 1 3 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 0 1 1.043-3.296 3.746 3.746 0 0 1 3.296-1.043A3.746 3.746 0 0 1 12 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 0 1 3.296 1.043 3.746 3.746 0 0 1 1.043 3.296A3.745 3.745 0 0 1 21 12Z" /></svg>
          </div>
          <div>
            <div class="trust-item-text" style="font-weight:600; color:var(--text); margin-bottom:0.25rem;">Practical implementation</div>
            <div class="trust-item-text">Not AI hype — focused on real business outcomes</div>
          </div>
        </div>

        <div class="trust-item reveal">
          <div class="trust-icon">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" /></svg>
          </div>
          <div>
            <div class="trust-item-text" style="font-weight:600; color:var(--text); margin-bottom:0.25rem;">Built for small business</div>
            <div class="trust-item-text">Designed for Australian SMEs, not enterprise departments</div>
          </div>
        </div>

        <div class="trust-item reveal">
          <div class="trust-icon">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.75" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17 17.25 21A2.652 2.652 0 0 0 21 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 1 1-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 0 0 4.486-6.336l-3.276 3.277a3.004 3.004 0 0 1-2.25-2.25l3.276-3.276a4.5 4.5 0 0 0-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085m-1.745 1.437L5.909 7.5H4.5L2.25 3.75l1.5-1.5L7.5 4.5v1.409l4.26 4.26m-1.745 1.437 1.745-1.437m6.615 8.206L15.75 15.75M4.867 19.125h.008v.008h-.008v-.008Z" /></svg>
          </div>
          <div>
            <div class="trust-item-text" style="font-weight:600; color:var(--text); margin-bottom:0.25rem;">Hands-on builder</div>
            <div class="trust-item-text">Strategy and implementation — not just advice</div>
          </div>
        </div>

      </div>
    </div>
  </section>


  <!-- ══════════════════════════════════════════════
       3. PROBLEMS
  ══════════════════════════════════════════════ -->
  <section id="problems" class="section">
    <div class="container">
      <span class="label reveal">Where time goes</span>
      <h2 class="display-lg reveal" style="max-width: 600px; margin-top: 0.5rem;">
        Where is your business losing time?
      </h2>
      <p class="body-lg reveal" style="max-width: 560px; margin-top: 1.25rem;">
        Most business owners know something is taking too long. They just don't have time to step back and fix it. Here's what we see most often.
      </p>

      <div class="problems-grid">
        <div class="problem-card">
          <div class="problem-num">01</div>
          <div class="problem-title">Customer enquiries taking too long to answer</div>
          <div class="problem-desc">Potential customers are waiting hours — or not hearing back at all. First impressions are being lost.</div>
        </div>
        <div class="problem-card">
          <div class="problem-num">02</div>
          <div class="problem-title">Staff repeating the same admin tasks</div>
          <div class="problem-desc">Good people are spending most of their day on work that could be automated. It burns them out and costs you.</div>
        </div>
        <div class="problem-card">
          <div class="problem-num">03</div>
          <div class="problem-title">Quotes, forms, and follow-ups handled manually</div>
          <div class="problem-desc">Every quote takes time. Every follow-up is easy to forget. The process is inconsistent and deals slip through.</div>
        </div>
        <div class="problem-card">
          <div class="problem-num">04</div>
          <div class="problem-title">Business knowledge trapped in one person's head</div>
          <div class="problem-desc">When that person is busy, sick, or leaves — the whole operation feels the gap immediately.</div>
        </div>
        <div class="problem-card">
          <div class="problem-num">05</div>
          <div class="problem-title">Content creation taking too much time</div>
          <div class="problem-desc">Social posts, emails, and website updates sit on the to-do list for weeks. Marketing falls behind because it takes too long.</div>
        </div>
        <div class="problem-card">
          <div class="problem-num">06</div>
          <div class="problem-title">Reports and spreadsheets updated by hand</div>
          <div class="problem-desc">Hours every week building the same reports. The data exists — it just takes too long to pull together.</div>
        </div>
      </div>
    </div>
  </section>


  <!-- ══════════════════════════════════════════════
       4. SOLUTION / HOW IT WORKS
  ══════════════════════════════════════════════ -->
  <section id="solution" class="section">
    <div class="container">
      <span class="label reveal">How Acceso AI works</span>
      <h2 class="display-lg reveal" style="margin-top: 0.5rem; max-width: 600px;">
        We find the bottlenecks, then build the system.
      </h2>
      <p class="body-lg reveal" style="max-width: 560px; margin-top: 1.25rem;">
        A clear, practical process — no jargon, no unnecessary complexity. Just honest analysis and real implementation.
      </p>

      <div class="steps-grid">
        <div class="step-card reveal">
          <div class="step-num">01</div>
          <div class="step-title">Assess</div>
          <div class="step-body">We review your business processes and identify where AI or automation could make a meaningful difference. The focus is on your specific situation, not generic frameworks.</div>
        </div>
        <div class="step-card reveal">
          <div class="step-num">02</div>
          <div class="step-title">Prioritise</div>
          <div class="step-body">We focus on the opportunities with the best mix of impact, cost, simplicity, and risk. Not everything AI can do is worth doing. We help you find what actually matters.</div>
        </div>
        <div class="step-card reveal">
          <div class="step-num">03</div>
          <div class="step-title">Implement</div>
          <div class="step-body">We build practical tools, workflows, automations, and AI systems that your team can actually use — without needing to understand the technology behind them.</div>
        </div>
      </div>
    </div>
  </section>


  <!-- ══════════════════════════════════════════════
       5. AI OPPORTUNITY ASSESSMENT
  ══════════════════════════════════════════════ -->
  <section id="assessment" class="section">
    <div class="container">
      <div class="assessment-card reveal-scale">
        <div>
          <span class="label">Free AI Opportunity Assessment</span>
          <h2 class="display-md" style="margin-top: 0.5rem; max-width: 520px;">
            Start with a free AI Opportunity Assessment.
          </h2>
          <p class="body-lg" style="margin-top: 1.25rem; max-width: 500px;">
            Not every business needs the same AI tools. The assessment helps identify where your business may be losing time, missing leads, or relying too heavily on manual processes.
          </p>
          <p class="body-md" style="margin-top: 1rem; max-width: 480px;">
            It covers four areas of your business and produces a personalised report showing where AI may be most useful — and where it might not be worth pursuing.
          </p>

          <div class="assessment-tags">
            <span class="tag">Marketing & Sales</span>
            <span class="tag">People & Operations</span>
            <span class="tag">Finance & Reporting</span>
            <span class="tag">Business Systems</span>
          </div>

          <div style="margin-top: 2rem; display: flex; flex-wrap: wrap; gap: 0.875rem; align-items: center;">
            <a href="[SCOREAPP_URL]" class="btn btn-primary">Take the Assessment</a>
            <span class="body-md" style="font-size: 0.8125rem;">Takes approximately 5–7 minutes. Free.</span>
          </div>
        </div>

        <div class="assessment-aside">
          <div class="assessment-aside-num">5–7</div>
          <div class="assessment-aside-label">minutes to complete<br />Personalised report included</div>
          <div style="margin-top: 1.5rem; padding-top: 1.25rem; border-top: 1px solid rgba(42,91,215,0.2);">
            <div style="font-size: 0.8125rem; color: var(--accent); font-weight: 500; line-height: 1.5;">Joel reviews every submission personally and only follows up with businesses he can genuinely help.</div>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- ══════════════════════════════════════════════
       6. USE CASES
  ══════════════════════════════════════════════ -->
  <section id="usecases" class="section">
    <div class="container">
      <span class="label reveal">What we build</span>
      <h2 class="display-lg reveal" style="margin-top: 0.5rem; max-width: 560px;">
        Practical AI use cases for real businesses.
      </h2>
      <p class="body-lg reveal" style="max-width: 540px; margin-top: 1.25rem;">
        These are not concepts or research projects. They are systems that can be built, implemented, and running in weeks.
      </p>

      <div class="usecases-grid">
        {useCases.map((uc, i) => (
          <div class="usecase-card reveal">
            <div class="usecase-icon">
              <Fragment set:html={uc.icon} />
            </div>
            <div class="usecase-title">{uc.title}</div>
            <div class="usecase-body">{uc.body}</div>
          </div>
        ))}
      </div>
    </div>
