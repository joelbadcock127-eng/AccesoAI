---
import Base from '../layouts/Base.astro';
import content from '../content/pages/index.html?raw';

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "name": "Acceso AI",
  "url": "https://www.accesoai.com.au/",
  "description": "AI consulting and automation support for small businesses.",
  "areaServed": {
    "@type": "Place",
    "name": "Tasmania, Australia"
  },
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Devonport",
    "addressRegion": "TAS",
    "addressCountry": "AU"
  },
  "serviceType": [
    "AI consulting",
    "Workflow automation",
    "Business process improvement",
    "AI opportunity assessment"
  ],
  "contactPoint": {
    "@type": "ContactPoint",
    "email": "Joel@bakerswalkingco.au",
    "contactType": "customer service"
  }
};
---

<Base
  title="Acceso AI | Practical AI Consulting for Tasmanian Businesses"
  description="Acceso AI helps Tasmanian small and medium businesses save time, reduce admin, and improve operations with practical AI and automation systems. Led by Joel Badcock in Devonport."
  path="/"
  jsonLd={jsonLd}
>
  <!-- Editable content: src/content/pages/index.html -->
  <Fragment set:html={content} />
</Base>
