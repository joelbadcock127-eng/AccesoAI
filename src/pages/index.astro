---
import Base from '../layouts/Base.astro';

const problems = [
  { num: "01", title: "Enquiries answered too slowly", desc: "Questions sit in inboxes while competitors reply first." },
  { num: "02", title: "Staff repeating the same admin", desc: "Hours each week on tasks a system could run in minutes." },
  { num: "03", title: "Quotes and reminders done by hand", desc: "Built from scratch, chased manually, or forgotten entirely." },
  { num: "04", title: "Knowledge trapped in one head", desc: "When that person is away, everything they know goes with them." },
  { num: "05", title: "Content that never gets made", desc: "Posts and emails that should take minutes take hours — or never happen." },
  { num: "06", title: "Reporting stitched together manually", desc: "Numbers pulled from three systems into a spreadsheet by hand." }
];

const marqueeItems = [
  "AI & Automation Officer at Devonport City Council",
  "Practical implementation, not theory",
  "Built for Tasmanian small business",
  "Real workflows, real outcomes",
  "Based in Devonport, Tasmania"
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "name": "Acceso AI",
  "url": "https://www.accesoai.com.au/",
  "description": "AI consulting and automation support for small businesses.",
  "areaServed": {
    "@type": "Place",
    "name": "Tasmania, Australia"
  },
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Devonport",
    "addressRegion": "TAS",
    "addressCountry": "AU"
  },
  "serviceType": [
    "AI consulting",
    "Workflow automation",
    "Business process improvement",
    "AI opportunity assessment"
  ],
  "contactPoint": {
    "@type": "ContactPoint",
    "email": "Joel@bakerswalkingco.au",
    "contactType": "customer service"
  }
};
---

<Base
  title="Acceso AI | Practical AI Consulting for Tasmanian Businesses"
  description="Acceso AI helps Tasmanian small and medium businesses save time, reduce admin, and improve operations with practical AI and automation systems."
  path="/"
  jsonLd={jsonLd}
>
  <!-- ═══ 1 · HERO ══════════════════════ -->
  <div class="hero-shell">
    <canvas class="net-canvas" aria-hidden="true"></canvas>
    <header class="hero wrap" id="top">
      <div class="hero-meta hero-fade">
        <span><span class="dot"></span><span data-scramble>Devonport, Tasmania</span></span>
        <span data-scramble>AI &amp; Automation Consulting</span>
        <span data-scramble>For Tasmanian Small Business</span>
      </div>

      <h1 data-split="hero">
        Practical AI systems that make your business <em>easier to run.</em>
      </h1>

      <p class="hero-sub lede hero-fade">
        We find the repetitive work hiding in your week, then build the
        AI and automation systems that remove it.
      </p>

      <div class="hero-ctas hero-fade">
        <a href="https://accesoai.scoreapp.com/" target="_blank" rel="noopener" class="btn btn-ink">
          Take the Free Assessment
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/></svg>
        </a>
        <a href="/services/" class="btn btn-line">Explore the Services</a>
      </div>

      <div class="flow hero-fade" aria-label="Example automated workflow">
        <p class="flow-label">An ordinary Tuesday, automated</p>
        <div class="flow-track">
          <span class="flow-step lit"><span class="pip"></span>Enquiry received, 9:41 am</span>
          <span class="flow-arrow" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/></svg>
          </span>
          <span class="flow-step lit" style="animation-delay:0.7s"><span class="pip" style="animation-delay:0.7s"></span>Reply drafted &amp; routed</span>
          <span class="flow-arrow" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/></svg>
          </span>
          <span class="flow-step lit"><span class="pip" style="animation-delay:1.4s"></span>Reminder scheduled</span>
        </div>
      </div>
    </header>
  </div>

  <!-- ═══ HERO PHOTO BAND ═══════════════ -->
  <div class="hero-band wrap" data-img-frame>
    <div class="img-frame img-parallax img-reveal">
      <img
        src="/2021_Devonport_Aerial.width-1440.jpg"
        alt="Aerial view of Devonport, Tasmania"
        loading="lazy"
      />
    </div>
    <p class="img-caption">Based in Devonport, Tasmania</p>
  </div>

  <!-- ═══ 2 · MARQUEE TRUST STRIP ═══════ -->
  <div class="marquee" aria-hidden="true">
    <div class="marquee-inner">
      <div class="marquee-group">
        {marqueeItems.map((m) => <span class="marquee-item">{m}</span>)}
      </div>
      <div class="marquee-group">
        {marqueeItems.map((m) => <span class="marquee-item">{m}</span>)}
      </div>
    </div>
  </div>

  <!-- ═══ 3 · PROBLEMS ══════════════════ -->
  <section class="section wrap" id="problems">
    <p class="eyebrow rv"><span class="idx">01</span> <span data-scramble>The Problem</span></p>
    <h2 class="display" data-split style="margin-bottom: clamp(2.5rem, 5vw, 4rem);">
      Where is your business <em>losing time?</em>
    </h2>

    <div class="problem-list">
      {problems.map((p) => (
        <div class="problem-row rv">
          <span class="problem-num">{p.num}</span>
          <h3 class="problem-title">{p.title}</h3>
          <p class="problem-desc">{p.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ═══ 4 · APPROACH ══════════════════ -->
  <section class="section wrap" id="approach">
    <div class="process-head">
      <div>
        <p class="eyebrow rv"><span class="idx">02</span> <span data-scramble>The Approach</span></p>
        <h2 class="display" data-split>Find the bottlenecks, <em>then build the system.</em></h2>
      </div>
      <p class="lede rv" style="max-width: 34ch; font-size: 1rem;">
        From conversation to working system, without the overcomplication.
      </p>
    </div>

    <div class="process-grid">
      <div class="process-progress" id="process-progress"></div>

      <div class="process-col rv" data-step>
        <p class="process-num">No.1</p>
        <h3>Assess</h3>
        <p>A review of how your business runs, to find where AI would genuinely save time or money.</p>
      </div>

      <div class="process-col rv" data-step>
        <p class="process-num">No.2</p>
        <h3>Prioritise</h3>
        <p>Opportunities ranked by impact, cost, and risk. The right ones first.</p>
      </div>

      <div class="process-col rv" data-step>
        <p class="process-num">No.3</p>
        <h3>Implement</h3>
        <p>Working systems your team actually uses. No abandoned prototypes.</p>
      </div>
    </div>
  </section>

  <!-- ═══ 5 · ASSESSMENT ════════════════ -->
  <section class="assessment section" id="assessment">
    <div class="wrap">
      <p class="eyebrow rv"><span class="idx" style="color:#7FA3F0;">03</span> <span data-scramble>Free Opportunity Assessment</span></p>
      <h2 data-split>Find out where AI could <em>actually help.</em></h2>
      <p class="lede rv">
        Six minutes. Four areas of your business. One personalised report.
      </p>

      <div class="assess-stats">
        <div class="assess-stat rv"><p class="val"><span data-count="6">0</span><em> min</em></p><p class="key">To complete</p></div>
        <div class="assess-stat rv"><p class="val"><span data-count="4">0</span><em> areas</em></p><p class="key">Sales · People · Finance · Systems</p></div>
        <div class="assess-stat rv"><p class="val"><span data-count="1">0</span><em> report</em></p><p class="key">Personalised to your business</p></div>
        <div class="assess-stat rv"><p class="val">$0</p><p class="key">Free, no obligation</p></div>
      </div>

      <div class="assess-ctas rv">
        <a href="https://accesoai.scoreapp.com/" target="_blank" rel="noopener" class="btn btn-paper">
          Take the Assessment
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/></svg>
        </a>
        <a href="mailto:Joel@bakerswalkingco.au" class="btn btn-ghost-dark">Or make a direct enquiry</a>
      </div>
      <p class="assess-note rv">Every submission is reviewed personally.</p>
    </div>
  </section>
</Base>
