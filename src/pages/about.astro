---
import Base from '../layouts/Base.astro';
import Finale from '../components/Finale.astro';

const faqs = [
  { q: "Do I need to understand AI before working with you?", a: "No. Most clients start with questions, not answers. That's exactly the right place to begin." },
  { q: "Is this only for large businesses?", a: "No — Acceso AI is built specifically for Tasmanian small and medium businesses: smaller teams, tighter budgets, real constraints." },
  { q: "What if AI isn't actually useful for my business?", a: "Then the honest recommendation is: don't use it. The goal is worthwhile opportunities, not forcing AI where it doesn't belong." },
  { q: "Will this replace my staff?", a: "No. AI takes the repetitive tasks that burn people out, so your team can focus on the work that matters." },
  { q: "Is my business data safe?", a: "Privacy and security are considered in every implementation, and recommendations always account for your data obligations." },
  { q: "How do I start?", a: "Take the free six-minute assessment, or email Joel directly if you already have a project in mind." }
];
---

<Base
  title="About Joel Badcock | Acceso AI"
  description="Acceso AI is led by Joel Badcock, an AI and automation practitioner based in Devonport, Tasmania — three years leading AI work at Devonport City Council."
  path="/about/"
>
  <!-- ═══ PAGE HERO ═════════════════════ -->
  <div class="hero-shell">
    <canvas class="net-canvas" aria-hidden="true"></canvas>
    <header class="page-hero wrap">
      <p class="eyebrow hero-fade"><span class="idx">01</span> <span data-scramble>About</span></p>
      <h1 data-split="hero">Who you're <em>working with.</em></h1>
      <p class="lede hero-fade">
        People buy consultants, not faceless companies. So here's exactly who you'd be dealing with.
      </p>
    </header>
  </div>

  <!-- ═══ ABOUT ═════════════════════════ -->
  <section class="about section" id="about" style="padding-top: clamp(3rem, 6vw, 5rem);">
    <div class="wrap">
      <div class="about-grid">
        <div class="about-media">
          <div class="img-frame img-reveal rv-l" data-img-frame>
            <img
              src="/joel-badcock.jpg"
              alt="Joel Badcock standing on a granite summit in Tasmania"
              loading="lazy"
            />
          </div>
          <p class="about-quote rv-l">
            Someone who understands the technology, has run a business, and will tell you the truth.
          </p>
        </div>

        <div class="about-body">
          <p class="rv">
            Acceso AI is led by Joel Badcock, an AI and automation practitioner in
            Devonport. He spent three years leading AI and automation work at
            Devonport City Council — turning what was happening at the frontier
            into systems that actually ran inside a real organisation.
          </p>
          <p class="rv">
            He also runs Bakers Walking Company, so he knows the other side of the
            table: the invoices, the staff, the decisions made with incomplete
            information. If AI isn't worth doing in your business, he'll say so.
          </p>

          <div class="about-sign rv">
            <span class="name">Joel Badcock</span>
            <span class="role">Founder, Acceso AI</span>
          </div>

          <ul class="about-facts rv">
            <li>Based in Tasmania</li>
            <li>AI &amp; Automation Officer</li>
            <li>Business owner</li>
            <li>Builds the systems himself</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ FAQ ═══════════════════════════ -->
  <section class="section wrap" id="faq">
    <p class="eyebrow rv"><span class="idx">02</span> <span data-scramble>Common Questions</span></p>
    <h2 class="display" data-split style="margin-bottom: clamp(2.5rem, 5vw, 4rem);">
      Asked often, <em>answered honestly.</em>
    </h2>

    <div class="faq-wrap">
      {faqs.map((f) => (
        <div class="faq-item rv" data-faq>
          <button class="faq-q" type="button" aria-expanded="false">
            <h3>{f.q}</h3>
            <span class="faq-x" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/></svg>
            </span>
          </button>
          <div class="faq-a"><p>{f.a}</p></div>
        </div>
      ))}
    </div>
  </section>

  <Finale />
</Base>
